# OpenAI API Settings
# Get your API key from: https://platform.openai.com/
OPENAI_API_KEY=
# Specify the model you want to use (e.g. gpt-4o-mini, gpt-4o)
OPENAI_MODEL=gpt-4o-mini

# Google Gemini API Settings (Alternative)
GEMINI_API_KEY=

# Force local Hugging Face model execution on CPU instead of using any API
USE_LOCAL_LLM=False
